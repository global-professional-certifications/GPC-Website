{
    "headers": [
      {
        "source": "/thumbnails/(.*)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/CIA-Brochure.pdf",
        "destination": "/api/brochure?course=cia"
      },
      {
        "source": "/CISA-Brochure.pdf",
        "destination": "/api/brochure?course=cisa"
      },
      {
        "source": "/:course-Brochure.pdf",
        "destination": "/api/brochure?course=:course"
      },
      {
        "source": "/(.*)",
        "destination": "/index.html"
      }
    ]
  }
  